{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "verdict": {
      "type": "string",
      "enum": ["proceed", "caution", "stop"]
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "claim": { "type": "string" },
          "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
          "evidence": { "type": "string" }
        },
        "required": ["claim", "confidence"]
      }
    },
    "questions": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "required": ["verdict", "findings"]
}
